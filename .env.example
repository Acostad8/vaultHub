# Copiar a .env.local y rellenar con valores reales del proyecto Supabase.
# NUNCA commitear .env.local ni SERVICE_ROLE_KEY.

# URL publica del proyecto Supabase (ejemplo: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave publica anon del proyecto Supabase (respetada por RLS, segura en cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
